#!/bin/sh

# --- 1. 函数: 禁用 IPv6 WAN 接口 ---
disable_wan6() {
  if uci -q get network.wan6 >/dev/null; then
    uci set network.wan6.disabled='1'
    uci commit network
    /etc/init.d/network reload 2>/dev/null || true
    echo "wan6接口已禁用"
  fi
}

# --- 2. 函数: 随机化 frpc 用户名 ---
randomize_frpc_user() {
  if uci -q get frpc.common.user >/dev/null; then
    # 使用 /dev/urandom 生成随机的小写字母用户名（长度 8）
    FRPC_USER=$(tr -dc 'a-z' </dev/urandom | head -c 8)
    uci set frpc.common.user="$FRPC_USER"
    uci commit frpc
    /etc/init.d/frpc restart 2>/dev/null || true
  fi
}

# ----------------------------------------
# 执行主程序
# ----------------------------------------
disable_wan6
randomize_frpc_user

exit 0
